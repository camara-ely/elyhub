{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ElyHub",
  "version": "0.1.8",
  "identifier": "app.ely.hub",
  "build": {
    "frontendDist": "../dist",
    "devUrl": null
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "ElyHub",
        "width": 1400,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 720,
        "center": true,
        "resizable": true,
        "transparent": false,
        "decorations": true,
        "fullscreen": false,
        "focus": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "backgroundColor": "#05060A"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://unpkg.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https://cdn.discordapp.com https://*.workers.dev; connect-src 'self' ipc: http://ipc.localhost https://discord.com https://cdn.discordapp.com https://*.workers.dev https://*.r2.cloudflarestorage.com https://github.com https://api.github.com https://objects.githubusercontent.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "nsis", "msi", "appimage", "deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "copyright": "© ElyHub",
    "category": "SocialNetworking",
    "shortDescription": "ElyHub — the Ely community home",
    "longDescription": "Leaderboards, rewards, trophies, and daily claims for the Ely Discord community.",
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "11.0",
      "exceptionDomain": "",
      "signingIdentity": null,
      "providerShortName": null,
      "entitlements": null
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com",
      "wix": {
        "language": ["en-US"]
      },
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico",
        "headerImage": null,
        "sidebarImage": null,
        "languages": ["English"],
        "displayLanguageSelector": false
      }
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/camara-ely/elyhub/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRCQUIxMDYwNzc1QjAxMUYKUldRZkFWdDNZQkNyUzZHcjZna2wrR2hzUlN3UGEzdzlxSUZlZWNrOHF3NHN6OTEwbGZOVUUzUG8K"
    }
  }
}
